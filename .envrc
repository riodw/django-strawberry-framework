# direnv config: auto-activate the uv-managed virtualenv whenever you
# cd into this repository.
#
# One-time setup (per machine, per checkout):
#   1. Install direnv:    brew install direnv
#   2. Hook it into zsh:  append `eval "$(direnv hook zsh)"` to ~/.zshrc,
#                         then `exec zsh` (or open a new terminal).
#   3. Authorize:         direnv allow
#
# Re-run `direnv allow` after any edit to this file. With the venv
# active, you can drop the `uv run` prefix on commands inside this
# directory tree (e.g. `pytest` instead of `uv run pytest`,
# `python scripts/review_diff_from_commit.py …` instead of
# `uv run python scripts/review_diff_from_commit.py …`).
watch_file pyproject.toml
watch_file uv.lock

# Create the venv on demand so first-time checkouts don't fail loudly
# before `uv sync` has been run.
if [ ! -d .venv ]; then
    if ! command -v uv >/dev/null 2>&1; then
        log_error "uv is required to create .venv; install it from https://docs.astral.sh/uv/"
        exit 1
    fi
    log_status "no .venv found; running 'uv sync' to create it"
    uv sync || exit $?
fi
# Activate the project venv. We deliberately skip `source .venv/bin/activate`
# because direnv evaluates this file in a bash subprocess and discards the
# script's PS1 mutation, and its `deactivate` function is redundant —
# direnv reverts VIRTUAL_ENV / PATH automatically when you cd out. Setting
# VIRTUAL_ENV plus `PATH_add` is the entire effective activation; the
# explicit VIRTUAL_ENV_PROMPT lets a zsh prompt hook render the (.venv)
# indicator and have it disappear automatically on cd-out.
export VIRTUAL_ENV="$PWD/.venv"
export VIRTUAL_ENV_PROMPT="(.venv) "
PATH_add "$VIRTUAL_ENV/bin"

# Convenience export some project scripts read.
export PROJECT_ROOT="$PWD"

# Match pytest.ini/example-project defaults for ad-hoc Django commands,
# Python REPL sessions, and direct `django-admin ...` usage from the repo
# root.
export DJANGO_SETTINGS_MODULE="config.settings"
export PYTHONPATH="$PWD/examples/fakeshop${PYTHONPATH:+:$PYTHONPATH}"
