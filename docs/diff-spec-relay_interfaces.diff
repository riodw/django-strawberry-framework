+@pytest.mark.django_db
+def test_resolve_id_uses_dict_cache():
+    """``resolve_id`` reads ``root.__dict__`` first (no extra lazy load)."""
+    services.seed_data(1)
+
+    class CategoryNode(DjangoType):
+        class Meta:
+            model = Category
+            fields = ("id", "name")
+            interfaces = (relay.Node,)
+
