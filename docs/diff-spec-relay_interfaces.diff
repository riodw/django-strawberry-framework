+        class Meta:
+            model = Category
+            fields = ("id", "name")
+            interfaces = (relay.Node,)
+
+        @classmethod
+        def get_queryset(cls, queryset, info, **kwargs):  # noqa: ARG003
+            return queryset.filter(is_private=False)
